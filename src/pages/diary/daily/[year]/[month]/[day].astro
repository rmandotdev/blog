---
import type { GetStaticPaths, MarkdownInstance } from "astro";

export const getStaticPaths = (async () => {
  const allPosts = import.meta.glob<MarkdownInstance<Record<string, unknown>>>(
    "/src/content/diary/daily/**/*.md"
  );

  console.log(allPosts);

  const paths = await Promise.all(
    Object.entries(allPosts).map(async ([path, getPost]) => {
      const slug: string = path
        .split("/src/content/diary/daily/")
        .at(-1)!
        .replace(".md", "");
      console.log(slug);
      const [year, month, day] = slug.split("/").map(Number);
      console.log(year, month, day);
      return { params: { year, month, day }, props: { post: await getPost() } };
    })
  );

  return paths;
}) satisfies GetStaticPaths;

const { post } = Astro.props;
---

<post.Content />
